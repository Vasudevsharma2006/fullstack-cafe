<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head", { title }) %>
  <body>
    <%- include("partials/nav-main") %>

    <main class="container py-5">
      <div class="mb-4">
        <h2 class="mb-1"><i class="fas fa-chart-pie me-2"></i>Dashboard</h2>
        <p class="text-muted mb-0">Quick overview of your cafe performance.</p>
      </div>

      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body">
              <p class="text-muted mb-2">Total Orders</p>
              <h3 class="mb-0"><%= totalOrders %></h3>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body">
              <p class="text-muted mb-2">Total Revenue</p>
              <h3 class="mb-0">&#8377; <%= totalRevenue.toFixed(2) %></h3>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body">
              <p class="text-muted mb-2">Menu Items</p>
              <h3 class="mb-0"><%= menuItemsCount %></h3>
            </div>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="card-header text-white">
          <h5 class="mb-0">Quick Stats</h5>
        </div>
        <div class="card-body">
          <p class="mb-2">
            <strong>Average Order Value:</strong>
            <% if (totalOrders > 0) { %> &#8377; <%= (totalRevenue /
            totalOrders).toFixed(2) %> <% } else { %> &#8377; 0.00 <% } %>
          </p>
          <p class="mb-2">
            <strong>Orders This Week:</strong> <%= totalOrders %> orders </p>
          <p class="mb-0">
            <strong>System Status:</strong>
            <span class="badge bg-success">Online</span>
          </p>
        </div>
      </div>
    </main>

    <%- include("partials/scripts", { includeMainJs: true }) %>
  </body>
</html>



