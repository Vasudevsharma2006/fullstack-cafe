<!DOCTYPE html>
<html lang="en">
    <%- include("../partials/head", { title }) %>
  <body>
        <%- include("../partials/nav-admin") %>

    <div class="container-fluid py-4">
      <div class="row mb-4">
        <div class="col-md-8">
          <h2><i class="fas fa-users"></i> Manage Staff</h2>
          <p class="text-muted">Manage café staff members</p>
        </div>
        <div class="col-md-4 text-end">
          <button
            type="button"
            class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#addStaffModal"
          >
            <i class="fas fa-user-plus"></i> Add Staff Member
          </button>
        </div>
      </div>
      <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <div class="row">
        <% staff.forEach(member => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
              <div class="text-center mb-3">
                <i class="fas fa-user fa-3x text-primary"></i>
              </div>
              <h5 class="card-title text-center"><%= member.name %></h5>
              <p class="card-text text-center text-muted mb-2">
                <small><strong><%= member.role %></strong></small>
              </p>
              <p class="card-text text-center text-muted mb-3">
                <small
                  ><i class="fas fa-envelope"></i> <%= member.email %></small
                >
              </p>
              <div class="text-center mb-3">
                <% if (member.status === 'Active') { %>
                <span class="badge bg-success">Active</span>
                <% } else { %>
                <span class="badge bg-danger">Inactive</span>
                <% } %>
              </div>
            </div>
            <div class="card-footer bg-light">
              <div class="d-flex gap-2">
                <button class="btn btn-sm btn-warning flex-grow-1">
                  <i class="fas fa-edit"></i> Edit
                </button>
                <button
                  class="btn btn-sm btn-danger flex-grow-1"
                  onclick="return confirm('Remove staff member?');"
                >
                  <i class="fas fa-trash"></i> Remove
                </button>
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- Add Staff Modal -->
    <div class="modal fade" id="addStaffModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Add New Staff Member</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>
          <div class="modal-body">
            <form method="POST" action="/admin/staff/add">
              <div class="mb-3">
                <label for="name" class="form-label">Full Name</label>
                <input
                  type="text"
                  class="form-control"
                  id="name"
                  name="name"
                  required
                />
              </div>
              <div class="mb-3">
                <label for="role" class="form-label">Role</label>
                <select class="form-control" id="role" name="role" required>
                  <option value="">Select Role</option>
                  <option value="Barista">Barista</option>
                  <option value="Chef">Chef</option>
                  <option value="Manager">Manager</option>
                  <option value="Cashier">Cashier</option>
                </select>
              </div>
              <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input
                  type="email"
                  class="form-control"
                  id="email"
                  name="email"
                  required
                />
              </div>
              <button type="submit" class="btn btn-primary w-100">
                Add Staff Member
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <footer class="bg-dark text-light py-4 mt-5">
      <div class="container">
        <p class="text-center mb-0">
          &copy; 2026 CAFE Admin Panel - All Rights Reserved
        </p>
      </div>
    </footer>

        <%- include("../partials/scripts", { includeMainJs: false }) %>
  </body>
</html>

