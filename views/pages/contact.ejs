<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head", { title }) %>
  <body>
    <%- include("../partials/nav-main") %>

    <section class="contact-hero py-5">
      <div class="container">
        <div class="row align-items-center g-4">
          <div class="col-lg-7">
            <span class="about-kicker">Contact CAFE</span>
            <h1 class="display-6 fw-bold mb-3">Let's Talk About Your Cafe Workflow</h1>
            <p class="lead mb-0">
              Questions, support, or setup help - our team is ready to assist you.
            </p>
          </div>
          <div class="col-lg-5">
            <div class="contact-mini-card">
              <i class="fas fa-headset"></i>
              <div>
                <strong>Quick Support</strong>
                <p class="mb-0">Mon-Fri, 9:00 AM to 6:00 PM</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container py-5">
      <div class="row g-4">
        <div class="col-lg-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4 p-lg-5">
              <h4 class="mb-3">Get In Touch</h4>
              <p class="text-muted mb-4">Fill the form and we will get back to you soon.</p>
              <% if (success) { %>
              <div class="alert alert-success"><%= success %></div>
              <% } %>
              <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
              <% } %>
              <form method="POST" action="/contact">
                <div class="mb-3">
                  <label for="name" class="form-label">Full Name</label>
                  <input
                    type="text"
                    class="form-control"
                    id="name"
                    name="name"
                    autocomplete="name"
                    required
                  />
                </div>

                <div class="mb-3">
                  <label for="email" class="form-label">Email Address</label>
                  <input
                    type="email"
                    class="form-control"
                    id="email"
                    name="email"
                    autocomplete="email"
                    required
                  />
                </div>

                <div class="mb-3">
                  <label for="subject" class="form-label">Subject</label>
                  <input
                    type="text"
                    class="form-control"
                    id="subject"
                    name="subject"
                    autocomplete="off"
                    required
                  />
                </div>

                <div class="mb-3">
                  <label for="message" class="form-label">Message</label>
                  <textarea
                    class="form-control"
                    id="message"
                    name="message"
                    rows="5"
                    required
                  ></textarea>
                </div>

                <button type="submit" class="btn btn-accent w-100">
                  <i class="fas fa-paper-plane me-1"></i>Send Message
                </button>
              </form>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="row g-3">
            <div class="col-12">
              <div class="card border-0 shadow-sm h-100 contact-info-card">
                <div class="card-body p-4">
                  <div class="contact-info-head">
                    <span class="contact-icon"><i class="fas fa-map-marker-alt"></i></span>
                    <h5 class="mb-0">Address</h5>
                  </div>
                  <p class="mb-0 mt-3">
                    123 Coffee Street<br />
                    Brew City, BC 12345<br />
                    United States
                  </p>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="card border-0 shadow-sm h-100 contact-info-card">
                <div class="card-body p-4">
                  <div class="contact-info-head">
                    <span class="contact-icon"><i class="fas fa-phone"></i></span>
                    <h5 class="mb-0">Phone</h5>
                  </div>
                  <p class="mb-0 mt-3">
                    Main: (123) 456-7890<br />
                    Support: (123) 456-7891
                  </p>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="card border-0 shadow-sm h-100 contact-info-card">
                <div class="card-body p-4">
                  <div class="contact-info-head">
                    <span class="contact-icon"><i class="fas fa-envelope"></i></span>
                    <h5 class="mb-0">Email</h5>
                  </div>
                  <div class="mt-3">
                  <p class="mb-2">
                    <strong>General Inquiry:</strong><br />
                    info@cafe.com
                  </p>
                  <p class="mb-2">
                    <strong>Support:</strong><br />
                    support@cafe.com
                  </p>
                  <p class="mb-0">
                    <strong>Sales:</strong><br />
                    sales@cafe.com
                  </p>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="card border-0 shadow-sm h-100 contact-hours-card">
                <div class="card-body p-4">
                  <div class="contact-info-head">
                    <span class="contact-icon"><i class="fas fa-clock"></i></span>
                    <h5 class="mb-0">Business Hours</h5>
                  </div>
                  <div class="mt-3">
                  <p class="mb-1">
                    <strong>Monday - Friday:</strong> 9:00 AM - 6:00 PM
                  </p>
                  <p class="mb-1">
                    <strong>Saturday:</strong> 10:00 AM - 4:00 PM
                  </p>
                  <p class="mb-0"><strong>Sunday:</strong> Closed</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include("../partials/scripts", { includeMainJs: false }) %>
  </body>
</html>




