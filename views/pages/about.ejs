<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head", { title }) %>
  <body>
    <%- include("../partials/nav-main") %>

    <section class="about-hero py-5">
      <div class="container">
        <div class="row align-items-center g-4">
          <div class="col-lg-7">
            <span class="about-kicker">About CAFE</span>
            <h1 class="display-5 fw-bold mb-3">Built for Cafe Teams That Move Fast</h1>
            <p class="lead mb-4">
              CAFE helps owners and staff manage orders, menu, reports, and daily
              operations with a clean and reliable workflow.
            </p>
            <div class="d-flex flex-wrap gap-2">
              <a href="/menu" class="btn btn-accent">
                <i class="fas fa-utensils me-1"></i>Explore Menu
              </a>
              <a href="/contact" class="btn btn-outline-primary">
                <i class="fas fa-envelope me-1"></i>Contact Us
              </a>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="about-feature-panel">
              <div class="about-feature-item">
                <i class="fas fa-bolt"></i>
                <span>Fast daily operations</span>
              </div>
              <div class="about-feature-item">
                <i class="fas fa-chart-line"></i>
                <span>Clear business insights</span>
              </div>
              <div class="about-feature-item">
                <i class="fas fa-user-shield"></i>
                <span>Role-based access control</span>
              </div>
              <div class="about-feature-item">
                <i class="fas fa-mobile-screen-button"></i>
                <span>Responsive on all devices</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-5">
      <div class="container">
        <div class="row g-4">
          <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body p-4 p-lg-5">
                <h3 class="mb-3">Our Story</h3>
                <p>
                  CAFE is a practical management platform designed for small and
                  medium cafes. It combines simple workflows with strong
                  features so teams can manage orders, menus, and staff without
                  friction.
                </p>
                <h3 class="mb-3 mt-4">Our Mission</h3>
                <p class="mb-0">
                  Our mission is to make daily cafe operations easier through a
                  fast, affordable, and easy-to-use system, so owners can focus
                  more on customer experience and quality service.
                </p>
              </div>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100 about-highlight-card">
              <div class="card-body p-4">
                <h5 class="mb-3">Why Teams Choose CAFE</h5>
                <ul class="about-check-list mb-0">
                  <li><i class="fas fa-circle-check"></i>Easy and clean UI</li>
                  <li><i class="fas fa-circle-check"></i>Menu and order control</li>
                  <li><i class="fas fa-circle-check"></i>Staff management tools</li>
                  <li><i class="fas fa-circle-check"></i>Reports and tracking</li>
                  <li><i class="fas fa-circle-check"></i>Secure session-based access</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-5">
      <div class="container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
          <h3 class="mb-0">Our Team</h3>
          <span class="text-muted">People behind the product</span>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center h-100">
              <div class="card-body p-4">
                <div class="about-avatar"><i class="fas fa-user"></i></div>
                <h5 class="mb-1">Sarah Johnson</h5>
                <p class="text-muted small mb-0">Founder & CEO</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center h-100">
              <div class="card-body p-4">
                <div class="about-avatar"><i class="fas fa-user"></i></div>
                <h5 class="mb-1">Mike Chen</h5>
                <p class="text-muted small mb-0">CTO</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center h-100">
              <div class="card-body p-4">
                <div class="about-avatar"><i class="fas fa-user"></i></div>
                <h5 class="mb-1">Lisa Rodriguez</h5>
                <p class="text-muted small mb-0">Operations Manager</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <%- include("../partials/scripts", { includeMainJs: false }) %>
  </body>
</html>




