<!DOCTYPE html>
<html>
  <%- include("partials/head", { title }) %>
  <body>
    <%- include("partials/nav-main") %>

    <main class="container my-5">
      <div class="text-center mb-5 fade-in">
        <h1 class="menu-section-title d-inline-block px-4">Our Menu</h1>
        <% if (user && user.role === 'admin') { %>
        <p class="mt-3">
          <a href="/admin/menu" class="btn btn-success"
            ><i class="fas fa-plus"></i> Add or Manage Items</a
          >
        </p>
        <% } %>
      </div>
      <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <!-- Search Bar -->
      <div
        class="row justify-content-center mb-4 fade-in"
        style="animation-delay: 0.1s"
      >
        <div class="col-md-6">
          <div class="input-group shadow-sm">
            <span class="input-group-text bg-white border-end-0"
              ><i class="fas fa-search text-muted"></i
            ></span>
            <input
              type="text"
              id="searchInput"
              class="form-control border-start-0 ps-0"
              placeholder="Search for coffee, snacks..."
            />
          </div>
        </div>
      </div>

      <!-- Category Filters -->
      <div class="text-center mb-5 fade-in" style="animation-delay: 0.2s">
        <div class="btn-group" role="group" aria-label="Menu Filters">
          <button
            type="button"
            class="btn btn-outline-primary menu-filter-btn active"
            data-category="all"
          >
            All Items
          </button>
          <% categories.forEach(category => { %>
          <button
            type="button"
            class="btn btn-outline-primary menu-filter-btn"
            data-category="<%= category %>"
          >
            <%= category %>
          </button>
          <% }); %>
        </div>
      </div>

      <div class="row g-4">
        <% menuItems.forEach(item => { %>
        <div
          class="col-lg-4 col-md-6 menu-item"
          data-category="<%= item.category %>"
        >
          <div class="food-card h-100 shadow-sm">
            <div class="food-card-image">
              <img
                src="<%= item.image || 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400&h=400&fit=crop' %>"
                alt="<%= item.name %>"
                loading="lazy"
                onerror="
                  this.src =
                    'https://via.placeholder.com/400x400?text=Food+Image'
                "
              />
              <span
                class="food-card-badge <%= item.available ? 'available' : 'unavailable' %>"
              >
                <%= item.available ? 'Available' : 'Sold Out' %>
              </span>
            </div>
            <div class="food-card-body">
              <span class="food-card-category"><%= item.category %></span>
              <h5 class="food-card-title"><%= item.name %></h5>
              <p class="food-card-description"><%= item.description %></p>
            </div>
            <div class="food-card-footer">
              <span class="food-card-price"
                >&#8377;
                <%= Number(item.price).toLocaleString("en-IN", {
                  minimumFractionDigits: 0,
                  maximumFractionDigits: 2,
                }) %></span
              >
              <div class="food-card-action">
                <% if (user && user.role === 'admin') { %>
                <a
                  href="/admin/menu/edit/<%= item.id %>"
                  class="btn btn-sm btn-outline-primary"
                  >Edit</a
                >
                <a
                  href="/admin/menu/delete/<%= item.id %>"
                  class="btn btn-sm btn-outline-danger"
                  onclick="
                    return confirm(
                      'Are you sure you want to delete this item?',
                    );
                  "
                  >Delete</a
                >
                <% } else { %>
                <form
                  action="/cart/add"
                  method="POST"
                  class="d-flex w-100 align-items-center"
                >
                  <div
                    class="input-group input-group-sm me-2"
                    style="width: 110px"
                  >
                    <button
                      type="button"
                      class="btn btn-outline-secondary"
                      id="minus-<%= item.id %>"
                    >
                      <i class="fas fa-minus"></i>
                    </button>
                    <input
                      type="number"
                      name="quantity"
                      id="quantity-<%= item.id %>"
                      value="1"
                      min="1"
                      max="10"
                      class="form-control text-center px-0"
                      readonly
                    />
                    <button
                      type="button"
                      class="btn btn-outline-secondary"
                      id="plus-<%= item.id %>"
                    >
                      <i class="fas fa-plus"></i>
                    </button>
                  </div>
                  <input type="hidden" name="itemId" value="<%= item.id %>" />
                  <button
                    type="submit"
                    class="btn btn-sm btn-primary flex-grow-1"
                  >
                    Add to Cart
                  </button>
                </form>
                <% } %>
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </main>

    <%- include("partials/scripts", { includeMainJs: true }) %>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const filterButtons = document.querySelectorAll(".menu-filter-btn");
        const menuItems = document.querySelectorAll(".menu-item");
        filterButtons.forEach((button) => {
          button.addEventListener("click", () => {
            filterButtons.forEach((btn) => btn.classList.remove("active"));
            button.classList.add("active");
            const category = button.dataset.category;
            menuItems.forEach((item) => {
              item.style.display =
                category === "all" || item.dataset.category === category
                  ? "block"
                  : "none";
            });
          });
        });
      });
    </script>
  </body>
</html>



