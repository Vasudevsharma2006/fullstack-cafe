<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head", { title }) %>
  <body>
    <%- include("../partials/nav-main") %>

    <main class="container py-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2 class="mb-1"><i class="fas fa-shopping-cart me-2"></i>My Cart</h2>
          <p class="text-muted mb-0">Review items before placing order</p>
        </div>
        <a href="/menu" class="btn btn-outline-primary">
          <i class="fas fa-plus me-1"></i>Add More Items
        </a>
      </div>

      <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (cartItems.length === 0) { %>
      <div class="alert alert-info text-center py-5">
        <i class="fas fa-inbox fa-3x mb-3"></i>
        <h4>Your cart is empty</h4>
        <p>Add food items from menu, then confirm order from here.</p>
        <a href="/menu" class="btn btn-accent">
          <i class="fas fa-list me-1"></i>Go to Menu
        </a>
      </div>
      <% } else { %>
      <div class="table-responsive mb-4">
        <table class="table table-hover align-middle">
          <thead class="table-dark">
            <tr>
              <th>Item</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Subtotal</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% cartItems.forEach((item) => { %>
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <img
                    src="<%= item.image || 'https://via.placeholder.com/80x80?text=Food' %>"
                    alt="<%= item.name %>"
                    width="60"
                    height="60"
                    class="rounded me-3"
                    style="object-fit: cover"
                  />
                  <div>
                    <div class="fw-bold"><%= item.name %></div>
                    <small class="text-muted"><%= item.category %></small>
                  </div>
                </div>
              </td>
              <td>&#8377; <%= item.price.toFixed(2) %></td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <form action="/cart/update" method="POST" class="m-0">
                    <input type="hidden" name="itemId" value="<%= item.itemId %>" />
                    <input
                      type="hidden"
                      name="quantity"
                      value="<%= item.quantity - 1 %>"
                    />
                    <button
                      type="submit"
                      class="btn btn-sm btn-outline-secondary"
                      <%= item.quantity <= 1 ? "disabled" : "" %>
                    >
                      <i class="fas fa-minus"></i>
                    </button>
                  </form>
                  <span class="badge bg-secondary"><%= item.quantity %></span>
                  <form action="/cart/update" method="POST" class="m-0">
                    <input type="hidden" name="itemId" value="<%= item.itemId %>" />
                    <input
                      type="hidden"
                      name="quantity"
                      value="<%= item.quantity + 1 %>"
                    />
                    <button
                      type="submit"
                      class="btn btn-sm btn-outline-secondary"
                      <%= item.quantity >= 10 ? "disabled" : "" %>
                    >
                      <i class="fas fa-plus"></i>
                    </button>
                  </form>
                </div>
              </td>
              <td class="fw-bold">&#8377; <%= item.subtotal.toFixed(2) %></td>
              <td>
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="itemId" value="<%= item.itemId %>" />
                  <button type="submit" class="btn btn-sm btn-outline-danger">
                    Remove
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="row justify-content-end">
        <div class="col-md-5">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Cart Summary</h5>
              <hr />
              <p class="d-flex justify-content-between">
                <span>Total Items</span>
                <strong><%= totalItems %></strong>
              </p>
              <p class="d-flex justify-content-between">
                <span>Total Amount</span>
                <strong>&#8377; <%= totalAmount.toFixed(2) %></strong>
              </p>
              <form action="/cart/confirm" method="POST" class="mt-3" id="confirmOrderForm">
                <button type="submit" class="btn btn-accent btn-lg w-100" id="confirmOrderBtn">
                  <i class="fas fa-check-circle me-1"></i>Confirm Order
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
      <% } %>
    </main>

    <%- include("../partials/scripts", { includeMainJs: false }) %>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const confirmOrderForm = document.getElementById("confirmOrderForm");
        const confirmOrderBtn = document.getElementById("confirmOrderBtn");
        if (!confirmOrderForm || !confirmOrderBtn) return;

        confirmOrderForm.addEventListener("submit", () => {
          confirmOrderBtn.disabled = true;
          confirmOrderBtn.innerHTML =
            '<i class="fas fa-spinner fa-spin me-1"></i>Processing...';
        });
      });
    </script>
  </body>
</html>



